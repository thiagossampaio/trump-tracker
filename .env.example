# .env.example
# Copie para .env e preencha os valores.
# NUNCA commite o .env com valores reais.

# ─── Supabase ─────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...

# ─── Anthropic (classificação) ────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── OpenAI (embeddings) ──────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Fontes de notícias ───────────────────────
# NewsAPI — https://newsapi.org (free: 100 req/dia)
NEWSAPI_KEY=

# Guardian — https://open-platform.theguardian.com (free)
GUARDIAN_API_KEY=

# ─── Telegram (moderação) ─────────────────────
# Criar bot via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# ID do chat do moderador
# Obter via @userinfobot no Telegram
TELEGRAM_CHAT_ID=

# ─── Frontend / Cloudflare ────────────────────
NEXT_PUBLIC_SITE_URL=https://trumptracker.pages.dev

# String aleatória para autenticar revalidação do Next.js
# Gerar com: openssl rand -hex 32
REVALIDATE_SECRET=

# ─── Opcional ─────────────────────────────────
# Perplexity API para enriquecimento contextual (fase 4)
PERPLEXITY_API_KEY=